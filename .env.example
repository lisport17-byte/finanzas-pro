# Copia este archivo como .env y completa con tus credenciales de Supabase
# Ve a https://supabase.com -> tu proyecto -> Settings -> API

VITE_SUPABASE_URL=https://TU_PROYECTO_ID.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY_AQUI

# Llave pública VAPID para notificaciones Web Push (Fase 1)
# La pareja pública/privada se genera una sola vez; la privada va como
# secreto de la Edge Function, NUNCA aquí.
VITE_VAPID_PUBLIC_KEY=TU_VAPID_PUBLIC_KEY
